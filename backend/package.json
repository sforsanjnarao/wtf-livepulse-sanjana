{
  "name": "wtf-livepulse-backend",
  "version": "1.0.0",
  "description": "WTF LivePulse backend API",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/app.ts",
